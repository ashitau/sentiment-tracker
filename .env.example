# ── Reddit API ────────────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=SentimentTracker/1.0 (by u/your_username)

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Free M0 cluster: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=sentiment_tracker

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Comma-separated list of allowed email addresses (no spaces around commas)
ALLOWED_EMAILS=analyst1@etnow.com,analyst2@etnow.com,analyst3@etnow.com

# Resend API key for sending magic link emails — free tier = 3000 emails/month
# Sign up at https://resend.com, verify your domain, get the API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── URLs ──────────────────────────────────────────────────────────────────────
# Set this to your actual Vercel deployment URL after first deploy
FRONTEND_URL=https://your-app.vercel.app

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
PIPELINE_INTERVAL_MINUTES=30
